<!DOCTYPE html>
<html lang="en" class="[scrollbar-gutter:stable]">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <meta name="csrf-token" content={get_csrf_token()} />
    <.live_title default="GameSite" suffix=" · Phoenix Framework">
      {assigns[:page_title]}
    </.live_title>
    <link phx-track-static rel="stylesheet" href={~p"/assets/app.css"} />
    <script defer phx-track-static type="text/javascript" src={~p"/assets/app.js"}>
    </script>
    <script src="https://cdn.jsdelivr.net/npm/canvas-confetti@1.9.2/dist/confetti.browser.min.js">
    </script>
    <style>
      /* Custom styles here if needed */
    </style>
  </head>
  <body class="bg-gray-50 min-h-screen flex flex-col">
    
<!-- User Nav -->
    <ul class="relative z-10 flex items-center gap-6 px-6 py-3 justify-end bg-white shadow-sm border-b border-gray-200 text-sm text-gray-900">
      <%= if @current_user do %>
        <li class="truncate max-w-xs">{@current_user.email}</li>
        <li>
          <.link href={~p"/users/settings"} class="font-semibold hover:text-gray-700">
            Settings
          </.link>
        </li>
        <li>
          <.link
            href={~p"/users/log_out"}
            method="delete"
            class="font-semibold hover:text-gray-700"
          >
            Log out
          </.link>
        </li>
      <% else %>
        <li>
          <.link href={~p"/users/register"} class="font-semibold hover:text-gray-700">
            Register
          </.link>
        </li>
        <li>
          <.link href={~p"/users/log_in"} class="font-semibold hover:text-gray-700">
            Log in
          </.link>
        </li>
      <% end %>
    </ul>
    
<!-- Navigation bar -->
    <nav class="bg-gray-700 z-20">
      <div class="max-w-6xl mx-auto px-4">
        <div class="flex flex-wrap justify-center gap-4 py-3 border">
          <.link navigate={~p"/"} class="nav-link">Home</.link>
          <.link navigate={~p"/scores"} class="nav-link">Scores</.link>

          <div x-data="{ open: false }" x-on:click.outside="open = false" class="relative">
            <button type="button" class="nav-link" x-on:click="open = !open">
              Single Player
            </button>

            <div
              x-show="open"
              class="absolute left-0 mt-2 bg-white rounded shadow-md min-w-[200px] z-30 overflow-hidden border border-gray-200"
            >
              <div class="flex flex-col">
                <.link navigate={~p"/guessing"} class="dropdown-link">Guessing Game</.link>
                <.link navigate={~p"/math"} class="dropdown-link">Math Game</.link>
                <.link navigate={~p"/rock-paper-scissors"} class="dropdown-link">
                  Rock Paper Scissors
                </.link>
                <.link navigate={~p"/wordle"} class="dropdown-link">Wordle</.link>
                <.link navigate={~p"/poker"} class="dropdown-link">Poker</.link>
                <.link navigate={~p"/pento_choice"} class="dropdown-link">Pento</.link>
              </div>
            </div>
          </div>

          <div x-data="{ open: false }" x-on:click.outside="open = false" class="relative">
            <button type="button" class="nav-link" x-on:click="open = !open">
              Multiplayer
            </button>

            <div
              x-show="open"
              class="absolute left-0 mt-2 bg-white rounded shadow-md min-w-[200px] z-30 overflow-hidden border border-gray-200"
            >
              <div class="flex flex-col">
                <.link navigate={~p"/multi-poker"} class="dropdown-link">Poker</.link>
              </div>
            </div>
          </div>
        </div>
      </div>
    </nav>
    
<!-- Main content -->
    <main class="flex-grow container mx-auto p-6">
      {@inner_content}
    </main>

    <style>
      .nav-link {
        @apply px-4 py-2 rounded-md text-gray-200 hover:bg-gray-600 hover:text-white font-semibold transition border border-white cursor-pointer bg-transparent;
      }

      .nav-link[aria-current="page"] {
        @apply bg-gray-900 text-white;
      }

      .dropdown-link {
        @apply px-3 py-2 text-gray-700 hover:bg-gray-100 transition;
        white-space: nowrap;
      }

      [x-cloak] {
        display: none !important;
      }
    </style>
  </body>
</html>
